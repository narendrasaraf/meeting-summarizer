# Provider selection 

# "openai"  → OpenAI Whisper + GPT (requires OPENAI_API_KEY)
# "groq"    → Groq Whisper + Llama — FREE, no credit card
#             https://console.groq.com
# "gemini"  → Google Gemini — FREE tier via Google AI Studio
#             ASR: Gemini multimodal File API
#             Summarisation: OpenAI-compatible endpoint
#             https://aistudio.google.com/apikey
PROVIDER=openai

# OpenAI (PROVIDER=openai) 
OPENAI_API_KEY=sk-your-openai-key-here
WHISPER_MODEL=whisper-1
SUMMARY_MODEL=gpt-4o-mini

# Groq (PROVIDER=groq) 
GROQ_API_KEY=gsk_your-groq-key-here
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_SUMMARY_MODEL=llama-3.3-70b-versatile

# Gemini (PROVIDER=gemini) 
GEMINI_API_KEY=AIza-your-gemini-key-here
GEMINI_ASR_MODEL=gemini-2.0-flash
GEMINI_SUMMARY_MODEL=gemini-2.0-flash

# Database 
DATABASE_URL=sqlite:///./meetings.db

# File storage 
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=50

# CORS 
CORS_ORIGINS=http://localhost:5173
