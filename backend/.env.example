# ─── Provider selection ────────────────────────────────────────────────────────
# "openai"  → OpenAI Whisper + GPT (satisfies "OpenAI Whisper" from the brief)
#             https://platform.openai.com/api-keys
# "groq"    → Groq Whisper large-v3 + Llama — FREE, no credit card
#             https://console.groq.com
# "gemini"  → Google Gemini multimodal audio transcription — FREE tier
#             (Gemini File API, not the same as Google Cloud Speech-to-Text)
#             https://aistudio.google.com/apikey
# "azure"   → Azure Cognitive Services Speech-to-Text SDK
#             (satisfies "Azure" from the brief)
#             https://portal.azure.com → Cognitive Services → Speech
# "google"  → Google Cloud Speech-to-Text v2
#             (satisfies "Google" from the brief — dedicated speech API)
#             https://console.cloud.google.com/speech
#             Auth: GOOGLE_APPLICATION_CREDENTIALS service account JSON
PROVIDER=openai

# OpenAI (PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key-here
WHISPER_MODEL=whisper-1
SUMMARY_MODEL=gpt-4o-mini

# Groq (PROVIDER=groq)
GROQ_API_KEY=gsk_your-groq-key-here
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_SUMMARY_MODEL=llama-3.3-70b-versatile

# Gemini (PROVIDER=gemini)
GEMINI_API_KEY=AIza-your-gemini-key-here
GEMINI_ASR_MODEL=gemini-2.0-flash
GEMINI_SUMMARY_MODEL=gemini-2.0-flash

# Azure Cognitive Services Speech (PROVIDER=azure)
# Get your key: portal.azure.com → Create resource → Cognitive Services → Speech
# Summarisation uses OPENAI_API_KEY + SUMMARY_MODEL (set those above too).
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=eastus

# Google Cloud Speech-to-Text v2 (PROVIDER=google)
# 1. Enable "Cloud Speech-to-Text API" in your GCP project.
# 2. Create a Service Account, download the JSON key.
# 3. Set GOOGLE_APPLICATION_CREDENTIALS to the path of that JSON file.
# Summarisation uses OPENAI_API_KEY + SUMMARY_MODEL (set those above too).
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
GOOGLE_STT_LOCATION=global

# Database
DATABASE_URL=sqlite:///./meetings.db

# File storage
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=50

# CORS
CORS_ORIGINS=http://localhost:5173

# Demo mode (optional)
# Set to true to skip all real API calls and return clearly-labelled fake content.
# Never use in production — the response is visibly marked "[SIMULATED]".
DEMO_MODE=false
